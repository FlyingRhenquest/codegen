#pragma once
#include <cereal/archives/binary.hpp>
#include <cereal/archives/json.hpp>
#include <cereal/archives/portable_binary.hpp>
#include <cereal/archives/xml.hpp>
#include <string>
#include <sstream>
#include <iostream>

/**
 * A config or something
 *
 * These are just some random things you might have in a config.
 * The point is to show how the code generation works.
 */

[[cereal]] struct Config {
  // Path to config file
  std::string configFileLocation;
  std::string searchPath;
  double gravitationalConstant;
  int numNipples;
  int approximatePi;
  std::string moreText;

  Config() = default;

  // Unpacks to cereal load/save methods
  
  [[genCerealLoadSave]]

  // We'll just use cereal to generate JSON or XML

  std::string to_json() {
    std::stringstream stream;
    {
      cereal::JSONOutputArchive ar(stream);
      this->save(ar);
    }
    return stream.str();
  }

  std::string to_xml() {
    std::stringstream stream;
    {
      cereal::XMLOutputArchive ar(stream);
      this->save(ar);
    }
    return stream.str();
  }

  void from_json(const std::string& s) {
    std::stringstream stream(s);
    {
      cereal::JSONInputArchive ar(stream);
      this->load(ar);
    }
  }

  void from_xml(const std::string& s) {
    std::stringstream stream(s);
    {
      cereal::XMLInputArchive ar(stream);
      this->load(ar);
    }
  }
  
};
